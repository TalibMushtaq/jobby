# Runtime mode used by Next.js and server logic.
NODE_ENV="development"
# Set to "true" for local development without valid Clerk keys.
# Keep "false" in production.
DEV_AUTH_BYPASS="false"

# PostgreSQL connection string used by Prisma.
# Example below matches the local Docker DB created for this project.
DATABASE_URL="postgresql://postgres:postgres@localhost:5440/jobby?schema=public"

# Clerk public key exposed to the browser for auth UI widgets.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
# Clerk server-side secret key used for auth/session validation.
CLERK_SECRET_KEY="sk_test_REPLACE_ME"
# Clerk webhook secret (required by current env validation).
CLERK_WEBHOOK_SIGNING_SECRET="whsec_REPLACE_ME"

# Clerk route URLs used by auth components and redirects.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# UploadThing API token used by the file upload route handler.
UPLOADTHING_TOKEN="UPLOADTHING_TOKEN_REPLACE_ME"

# OpenRouter API key for AI reasoning/optimization requests.
OPENROUTER_API_KEY="OPENROUTER_API_KEY_REPLACE_ME"
# OpenRouter model ID (free default used by this project).
OPENROUTER_MODEL="openai/gpt-oss-20b:free"
